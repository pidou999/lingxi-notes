# ============ Database ============
DATABASE_URL=postgres://ainotes:ainotes@localhost:5432/ainotes?sslmode=disable

# ============ Redis ============
REDIS_URL=redis://localhost:6379/0

# ============ MinIO (Object Storage) ============
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=ainotes
MINIO_SECRET_KEY=ainotes_secret
MINIO_BUCKET=ainotes

# ============ JWT ============
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRY=24h

# ============ AI Models ============
# Default AI provider (compatible with OpenAI API format)
# Users can configure multiple providers in app settings
AI_DEFAULT_PROVIDER=https://api.openai.com/v1
AI_DEFAULT_API_KEY=sk-your-key-here
AI_DEFAULT_MODEL=gpt-4o

# ============ Scraper ============
SCRAPER_URL=http://localhost:9090

# ============ Server ============
API_PORT=8080
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000

# ============ Next.js ============
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
